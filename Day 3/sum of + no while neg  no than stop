#include <iostream>
using namespace std;

int main() {
    int num, sum = 0;

    cout << "Enter numbers (negative number to stop):\n";

    while (true) {
        cin >> num;

        if (num < 0) {
            break;
        }

        if (num > 0) {
            sum += num;
        }
    }

    cout << "Sum of positive numbers = " << sum;

    return 0;
}
