#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter a number: ";
    cin >> n;

    int i = 1;

    cout << "Numbers divisible by 2 from 1 to " << n << " are:\n";

    while(i <= n) {
        if(i % 2 == 0) {
            cout << i << " ";
        }
        i++;
    }

    return 0;
}
