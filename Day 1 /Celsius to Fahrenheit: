#include <iostream>
using namespace std;

int main() {
    int celsius;
    float fahrenheit;

    cout << "Enter temperature in Celsius: ";
    cin >> celsius;

    // Convert Celsius to Fahrenheit
    fahrenheit = (9.0 / 5) * celsius + 32;

    cout << "Temperature in Fahrenheit: " << fahrenheit << endl;

    return 0;
}
