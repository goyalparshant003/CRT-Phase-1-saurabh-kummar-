#include <iostream>
using namespace std;

int main() {
    int a, b, c;

    cout << "Enter three sides of triangle: ";
    cin >> a >> b >> c;

    // Check if all sides are equal (Equilateral Triangle)
    if (a == b && b == c) {
        cout << "true (Equilateral Triangle)" << endl;
    } else {
        cout << "false" << endl;
    }

    return 0;
}
