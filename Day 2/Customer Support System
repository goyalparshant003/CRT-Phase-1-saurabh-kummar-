#include <iostream>
using namespace std;

int main() {
    int choice;

    cout << "===== Customer Support System =====" << endl;
    cout << "Press 1 for Support" << endl;
    cout << "Press 2 for Billing" << endl;
    cout << "Press 3 for Technical Issue" << endl;
    cout << "Press 0 to Exit" << endl;
    cout << "Enter your choice: ";
    cin >> choice;

    switch(choice) {
        case 1:
            cout << "You selected Support. Our team will assist you shortly." << endl;
            break;

        case 2:
            cout << "You selected Billing. Please wait while we connect you to billing department." << endl;
            break;

        case 3:
            cout << "You selected Technical Issue. A technician will help you soon." << endl;
            break;

        case 0:
            cout << "Thank you for calling. Goodbye!" << endl;
            break;

        default:
            cout << "Invalid choice! Please try again." << endl;
    }

    return 0;
}
